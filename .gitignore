# Build artifacts
/target/
**/target/
# Some crates use `target-test/` as an alternate cargo build dir for the
# host test profile (separate from the cross-compile `target/`). Same
# contents — codegen units, rlibs — that we never want to commit.
**/target-test/
**/*.rs.bk
# Stray rustc codegen-unit objects written to the Windows `nul` device name
# (these land in the crate root, not target/, when a build/clippy invocation
# redirects output to `nul` on Windows).
**/nul.*.rcgu.o

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS images
*.iso
*.img
*.hdd
*.ext4

# Limine binary artifacts (downloaded at build time)
/limine/

# Reference upstream clones (study material; embedded git repos, never tracked)
/dolphin/
/kglobalaccel/
/nushell/
/plasma-desktop/
/plasma-workspace/

# Toolchain sysroot — populated by cargo build of `posix` and
# `toolchain/stubs` (libc.a, libstubs.a, libunwind.a). Pure build
# output that must be regenerated per-machine; never commit.
/toolchain/sysroot/

# Orchestrator history (personal)
.orchestrator_history

# Saved web pages (reference material, not code)
*.html
*_files/

# OS-specific
Thumbs.db
Desktop.ini
.DS_Store

# Local safety backup taken before the 2026-06-13 todo.txt issue migration
todo.backup-*.txt

# --- Build/test artifacts purged from history 2026-07-11 (never re-track) ---
# The scratch build output dir: staged kernel, ELF/nm dumps, boot logs, etc.
# Regenerated every build; must never be committed.
/build/
# ESP staging: the bootable kernel + firmware nvram are build outputs.
# Keep esp/limine.conf and esp/EFI/BOOT/BOOTX64.EFI (config + bootloader);
# ignore the regenerated binaries.
esp/boot/kernel
esp/EFI/BOOT/kernel.bin
esp/NvVars
# All log files are transient (serial captures, boot/clippy/qemu runs).
*.log
# Clippy / build stdout+stderr capture dumps written to the repo root.
clippy_*.json
clippy_err.txt
clippy_out.txt
clippy_output.txt
clippy_sweep.txt
clippy_warning_counts.txt
build_check.txt
build_err.txt
build_out.txt
build_out2.txt
build_out3.txt
build_output.txt
boot_output.txt
full_build.txt
