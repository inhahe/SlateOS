# Build artifacts
/target/
**/target/
# Some crates use `target-test/` as an alternate cargo build dir for the
# host test profile (separate from the cross-compile `target/`). Same
# contents — codegen units, rlibs — that we never want to commit.
**/target-test/
**/*.rs.bk
# Stray rustc codegen-unit objects written to the Windows `nul` device name
# (these land in the crate root, not target/, when a build/clippy invocation
# redirects output to `nul` on Windows).
**/nul.*.rcgu.o

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS images
*.iso
*.img
*.hdd

# Limine binary artifacts (downloaded at build time)
/limine/

# Reference upstream clones (study material; embedded git repos, never tracked)
/dolphin/
/kglobalaccel/
/nushell/
/plasma-desktop/
/plasma-workspace/

# Toolchain sysroot — populated by cargo build of `posix` and
# `toolchain/stubs` (libc.a, libstubs.a, libunwind.a). Pure build
# output that must be regenerated per-machine; never commit.
/toolchain/sysroot/

# Orchestrator history (personal)
.orchestrator_history

# Saved web pages (reference material, not code)
*.html
*_files/

# OS-specific
Thumbs.db
Desktop.ini
.DS_Store

# Local safety backup taken before the 2026-06-13 todo.txt issue migration
todo.backup-*.txt
